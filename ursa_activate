#!/usr/bin/env bash
# Ursa Environment Activation Script
# ==========================================
# This script must be SOURCED, not executed:
#   source ./ursa_activate
#
# It will:
#   1. Build the URSA conda environment from config/ursa_env.yaml if it doesn't exist
#   2. Activate the URSA conda environment
#   3. Expose the repo-local commands and Python package path
#   4. Validate the required CLI tools from the canonical Conda environment

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

CONDA_ENV_NAME="URSA"

log_info() {
    printf "${CYAN}→${NC} %s\n" "$1"
}

log_success() {
    printf "${GREEN}✓${NC} %s\n" "$1"
}

log_warn() {
    printf "${YELLOW}⚠${NC} %s\n" "$1"
}

log_error() {
    printf "${RED}✗${NC} %s\n" "$1"
}

_ursa_return_or_exit() {
    return "$1" 2>/dev/null || exit "$1"
}

fail_activate() {
    log_error "$1"
    return 1
}

require_tool() {
    tool_scope="$1"
    tool_name="$2"
    if ! command -v "$tool_name" >/dev/null 2>&1; then
        fail_activate "Required ${tool_scope} tool '$tool_name' is missing"
        return 1
    fi
}

require_python_import() {
    module_name="$1"
    package_hint="$2"
    if ! python - "${module_name}" >/dev/null 2>&1 <<'PY'
import importlib
import sys

importlib.import_module(sys.argv[1])
PY
    then
        fail_activate "Required Python package '${package_hint}' is missing from the ${CONDA_ENV_NAME} environment"
        printf "   Rebuild with: ${CYAN}conda env create -n ${CONDA_ENV_NAME} -f ${ENV_FILE}${NC}\n"
        return 1
    fi
}

if [ -n "${BASH_VERSION:-}" ] && [ "${BASH_SOURCE[0]}" = "$0" ]; then
    printf "Error: This script must be sourced, not executed.\n"
    printf "Usage: source ./ursa_activate\n"
    exit 1
fi

_ursa_script_path() {
    if [ -n "${ZSH_VERSION:-}" ]; then
        printf '%s\n' "${(%):-%N}"
    elif [ -n "${BASH_SOURCE[0]:-}" ]; then
        printf '%s\n' "${BASH_SOURCE[0]}"
    else
        printf '%s\n' "$0"
    fi
}

_URSA_SCRIPT_PATH="$(_ursa_script_path)"
SCRIPT_DIR="$(cd "$(dirname "${_URSA_SCRIPT_PATH}")" 2>/dev/null && pwd)"
unset _URSA_SCRIPT_PATH

if [ ! -f "${SCRIPT_DIR}/config/ursa_env.yaml" ]; then
    SCRIPT_DIR="$(pwd)"
    while [ ! -f "${SCRIPT_DIR}/config/ursa_env.yaml" ] && [ "${SCRIPT_DIR}" != "/" ]; do
        SCRIPT_DIR="$(dirname "${SCRIPT_DIR}")"
    done
fi

ENV_FILE="${SCRIPT_DIR}/config/ursa_env.yaml"
BIN_DIR="${SCRIPT_DIR}/bin"

ursa_activate_main() {
    printf "\n${BOLD}${BLUE}╔══════════════════════════════════════════════════════════════╗${NC}\n"
    printf "${BOLD}${BLUE}║               Ursa Conda environment activation            ║${NC}\n"
    printf "${BOLD}${BLUE}╚══════════════════════════════════════════════════════════════╝${NC}\n\n"

    if ! command -v conda >/dev/null 2>&1; then
        fail_activate "Conda is required for Ursa activation"
        return 1
    fi

    if [ ! -f "$ENV_FILE" ]; then
        fail_activate "Environment file not found: $ENV_FILE"
        return 1
    fi

    if [ -n "${ZSH_VERSION:-}" ]; then
        eval "$(conda shell.zsh hook 2>/dev/null)" 2>/dev/null || true
    elif [ -n "${BASH_VERSION:-}" ]; then
        eval "$(conda shell.bash hook 2>/dev/null)" 2>/dev/null || true
    else
        CONDA_BASE="$(conda info --base 2>/dev/null)"
        if [ -f "${CONDA_BASE}/etc/profile.d/conda.sh" ]; then
            . "${CONDA_BASE}/etc/profile.d/conda.sh"
        fi
        unset CONDA_BASE
    fi

    if conda info --envs | grep -q "^${CONDA_ENV_NAME}[[:space:]]"; then
        log_success "Environment '${CONDA_ENV_NAME}' already exists"
    else
        log_info "Environment '${CONDA_ENV_NAME}' not found. Building from ${ENV_FILE}..."
        log_info "This may take a few minutes..."
        if ! (cd "${SCRIPT_DIR}" && conda env create -n "$CONDA_ENV_NAME" -f "$ENV_FILE"); then
            fail_activate "Failed to create conda environment '${CONDA_ENV_NAME}'"
            return 1
        fi
        log_success "Environment '${CONDA_ENV_NAME}' created successfully"
    fi

    log_info "Activating environment '${CONDA_ENV_NAME}'..."
    if ! conda activate "$CONDA_ENV_NAME"; then
        fail_activate "Failed to activate conda environment '${CONDA_ENV_NAME}'"
        return 1
    fi
    log_success "Activated conda environment: ${CONDA_ENV_NAME}"

    if [ -n "${CONDA_PREFIX:-}" ] && [ -x "${CONDA_PREFIX}/bin/python" ]; then
        export PATH="${CONDA_PREFIX}/bin:${PATH}"
    fi

    if ! command -v python >/dev/null 2>&1; then
        fail_activate "Activated conda environment does not expose python"
        return 1
    fi

    _URSA_PYTHON_BIN="$(dirname "$(command -v python)")"
    case ":$PATH:" in
        *":${_URSA_PYTHON_BIN}:"*)
            ;;
        *)
            export PATH="${_URSA_PYTHON_BIN}:${PATH}"
            ;;
    esac
    unset _URSA_PYTHON_BIN

    if [ -d "$BIN_DIR" ]; then
        case ":$PATH:" in
            *":${BIN_DIR}:"*)
                ;;
            *)
                export PATH="${BIN_DIR}:${PATH}"
                log_success "Added ${BIN_DIR} to PATH"
                ;;
        esac
    fi

    case ":$PATH:" in
        *":${SCRIPT_DIR}:"*)
            ;;
        *)
            export PATH="${SCRIPT_DIR}:${PATH}"
            log_success "Added ${SCRIPT_DIR} to PATH"
            ;;
    esac

    case ":${PYTHONPATH:-}:" in
        *":${SCRIPT_DIR}:"*)
            ;;
        *)
            if [ -n "${PYTHONPATH:-}" ]; then
                export PYTHONPATH="${SCRIPT_DIR}:${PYTHONPATH}"
            else
                export PYTHONPATH="${SCRIPT_DIR}"
            fi
            log_success "Added ${SCRIPT_DIR} to PYTHONPATH"
            ;;
    esac

    export URSA_ROOT="${SCRIPT_DIR}"
    export TAPDB_ENV="${TAPDB_ENV:-dev}"
    export TAPDB_CLIENT_ID="${TAPDB_CLIENT_ID:-local}"
    export TAPDB_DATABASE_NAME="${TAPDB_DATABASE_NAME:-ursa}"
    export TAPDB_STRICT_NAMESPACE="${TAPDB_STRICT_NAMESPACE:-1}"
    if [ -z "${TAPDB_CONFIG_PATH:-}" ]; then
        export TAPDB_CONFIG_PATH="${HOME}/.config/tapdb/${TAPDB_CLIENT_ID}/${TAPDB_DATABASE_NAME}/tapdb-config.yaml"
    fi

    require_tool "conda env" "aws" || return 1
    require_tool "conda env" "pcluster" || return 1
    require_tool "conda env" "jq" || return 1
    require_tool "conda env" "yq" || return 1
    require_tool "conda env" "rclone" || return 1
    require_tool "conda env" "parallel" || return 1
    require_tool "conda env" "perl" || return 1
    require_tool "conda env" "yamllint" || return 1
    require_tool "conda env" "fd" || return 1
    require_tool "conda env" "psql" || return 1
    require_tool "conda env" "node" || return 1
    require_tool "conda env" "ipython" || return 1
    require_python_import "daylily_tapdb" "daylily-tapdb==3.0.3" || return 1
    require_python_import "daylily_cognito" "daylily-cognito>=0.1.28" || return 1
    require_python_import "cli_core_yo" "../cli-core-yo" || return 1
    require_python_import "fastapi" "fastapi" || return 1
    require_python_import "pydantic_settings" "pydantic-settings" || return 1

    URSA_CONFIG_FILE="${HOME}/.config/ursa/ursa-config.yaml"
    URSA_CONFIG_LEGACY="${HOME}/.ursa/ursa-config.yaml"
    URSA_CONFIG_EXAMPLE="${SCRIPT_DIR}/config/ursa-config.example.yaml"

    if [ -f "$URSA_CONFIG_FILE" ]; then
        log_success "Config file found: ${URSA_CONFIG_FILE}"
    elif [ -f "$URSA_CONFIG_LEGACY" ]; then
        log_warn "Config file found at legacy path: ${URSA_CONFIG_LEGACY}"
        printf "   Consider moving to: ${CYAN}mkdir -p ~/.config/ursa && mv ${URSA_CONFIG_LEGACY} ${URSA_CONFIG_FILE}${NC}\n"
    else
        log_warn "Config file not found: ${URSA_CONFIG_FILE}"
        printf "   Create it with: ${CYAN}mkdir -p ~/.config/ursa && cp ${URSA_CONFIG_EXAMPLE} ${URSA_CONFIG_FILE}${NC}\n"
    fi

    if [ -n "${PS1:-}" ]; then
        _ursa_shell="$(basename "${SHELL:-}")"
        if [ "${_ursa_shell}" = "zsh" ]; then
            eval "$(ursa --show-completion zsh 2>/dev/null)" 2>/dev/null || true
        elif [ "${_ursa_shell}" = "bash" ]; then
            eval "$(ursa --show-completion bash 2>/dev/null)" 2>/dev/null || true
        fi
        unset _ursa_shell
    fi

    if command -v rehash >/dev/null 2>&1; then
        rehash
    elif command -v hash >/dev/null 2>&1; then
        hash -r 2>/dev/null || true
    fi

    printf "\n${BOLD}${GREEN}╔══════════════════════════════════════════════════════════════╗${NC}\n"
    printf "${BOLD}${GREEN}║  ✓ Ursa environment ready!                                   ║${NC}\n"
    printf "${BOLD}${GREEN}╚══════════════════════════════════════════════════════════════╝${NC}\n\n"
    printf "  ${CYAN}Conda Environment:${NC} %s\n" "${CONDA_ENV_NAME}"
    printf "  ${CYAN}Python:${NC}           %s\n" "$(python --version 2>&1 | cut -d' ' -f2)"
    printf "  ${CYAN}Project Root:${NC}     %s\n" "${SCRIPT_DIR}"
    printf "  ${CYAN}TapDB Env:${NC}        %s\n" "${TAPDB_ENV}"
    printf "  ${CYAN}TapDB Namespace:${NC}  %s/%s\n" "${TAPDB_CLIENT_ID}" "${TAPDB_DATABASE_NAME}"
    printf "\n"
    printf "  ${BOLD}Command Groups:${NC}\n"
    printf "    ${CYAN}ursa server${NC}   API server management\n"
    printf "    ${CYAN}ursa env${NC}      Environment and tooling status\n"
    printf "    ${CYAN}ursa quality${NC}  Linting and validation helpers\n"
    printf "    ${CYAN}ursa config${NC}   Configuration helpers\n"
    printf "    ${CYAN}daycog${NC}        Cognito/SSO management via daylily-cognito\n"
    printf "\n"
    printf "  ${BOLD}Quick Start:${NC}\n"
    printf "    ursa --help\n"
    printf "    ursa env status\n"
    printf "    ursa server start\n"
    printf "\n"
    printf "  ${BOLD}Deactivate:${NC}\n"
    printf "    conda deactivate\n\n"
}

ursa_activate_main "$@" || _ursa_return_or_exit $?
